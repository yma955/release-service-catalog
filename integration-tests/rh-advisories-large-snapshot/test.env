uuid=${uuid:-"$(openssl rand -hex 4)"}
uuid="${uuid:0:8}"

export originating_tool="rh-advisories-large-snapshot-test"

# IMPORTANT: Hardcoded namespaces for staging cluster (stg-rh01)
# These are the DEFAULT namespaces for LOCAL test runs
# 
# NOTE: PaC runs (triggered by /test-large-snapshot) use rhtap-release-2-tenant
#       This difference is intentional for environment isolation
#
# tenant_namespace: Where Application, Component, Release resources are created
# managed_namespace: Where ReleasePlanAdmission and release pipelines run
#
# To override tenant_namespace for local runs (e.g., to match PaC):
#   export tenant_namespace=rhtap-release-2-tenant
#   ../run-test.sh rh-advisories-large-snapshot
#
# Required permissions for any tenant namespace:
#   - Resource creation/deletion in both namespaces
#   - Access to secrets: vault-password-secret, github-token-secret, kubeconfig-secret
#   - ServiceAccount with release permissions
#   - ReleasePlanAdmission configured in managed namespace
export tenant_namespace="${tenant_namespace:-dev-release-team-tenant}"
export managed_namespace="${managed_namespace:-managed-release-team-tenant}"

export application_name=rh-adv-large-app-${uuid}
export component_type=rh-adv-large
export component_name=${component_type}-${uuid}
export component_branch=${component_name}
## do not change this. it is a known branch created by Konflux
export appstudio_component_branch="appstudio-${component_name}"

export component_github_org=hacbs-release-tests
export component_base_branch=${component_type}-base
export component_repo_name=${component_github_org}/${component_name}
export component_base_repo_name=${component_github_org}/e2e-base
export component_git_url=https://github.com/$component_repo_name

export tenant_sa_name=${component_type}-sa-${uuid}
export release_plan_name=${component_type}-rp-${uuid}

export managed_sa_name=${component_type}-sa-${uuid}
export release_plan_admission_name=${component_type}-rpa-${uuid}

# Large snapshot configuration
# Number of components to generate in the large snapshot
export LARGE_SNAPSHOT_COMPONENT_COUNT="${LARGE_SNAPSHOT_COMPONENT_COUNT:-200}"

# Pipeline timeout for large snapshot processing (Go duration format)
# Used in ReleasePlanAdmission and PaC PipelineRun
# Default: 8 hours for processing ~200 components
export LARGE_SNAPSHOT_TIMEOUT="${LARGE_SNAPSHOT_TIMEOUT:-8h0m0s}"

# This test uses a large snapshot with pre-built components
# to avoid building components during the test
export use_large_snapshot="true"
export large_snapshot_name="rh-advisories-large-snapshot-${uuid}"
