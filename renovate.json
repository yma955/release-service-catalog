{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "rebaseWhen": "behind-base-branch",
  "tekton": {
    "schedule": ["* 0-4 * * *"],
    "managerFilePatterns": ["/\\.yaml$/", "/\\.yml$/"],
    "ignorePaths": [],
    "includePaths": [
      ".tekton/**",
      "integration-tests/**",
      "tasks/**",
      "pipelines/**"
    ],
    "packageRules": [
      {
        "matchPackageNames": ["*"],
        "enabled": false
      },
      {
        "matchPackageNames": [
          "quay.io/konflux-ci/release-service-utils",
          "quay.io/conforma/cli"
        ],
        "enabled": true
      }
    ]
  }
}
